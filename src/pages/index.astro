---
import Layout from '../layouts/Layout.astro';
---

<Layout 
    title="AuraScaleLabs | Industrial Intelligence & Process Automation"
    description="Engineering high-performance autonomy for modern enterprises. Custom AI infrastructure, n8n automation, and data engineering solutions."
>
  
    <div class="background-grid"></div>
    <canvas id="connections-canvas"></canvas>

    <nav id="navbar">
        <div class="nav-container">
            <div class="logo">AuraScale<span class="highlight">Labs</span></div>
            <div class="nav-links">
                <a href="#services">Services</a>
                <a href="#work">Case Studies</a>
                <a href="#process">Process</a>
                <a href="#tech">Tech Stack</a>
                <a href="#contact" class="cta-button">Start Project</a>
            </div>
            <button class="mobile-menu-btn" id="mobile-menu-btn">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </nav>

    <main>
        <section class="hero" id="hero-section">
            
            
            <div class="hero-content">
                <div class="badge">EST. 2026 // SYSTEM ARCHITECTS</div>
                <h1>Engineering High-Performance <br/><span class="text-gradient">Autonomy</span></h1>
                <p class="subtitle">
                    We bridge the gap between complex data and operational growth. 
                    <strong>AuraScaleLabs</strong> builds custom AI infrastructure that allows your business to scale without increasing headcount.
                </p>
                
                <div class="hero-cta">
                    <a href="#contact" class="primary-btn">Request Audit</a>
                    <a href="#work" class="secondary-btn">View Work</a>
                </div>
                    <div class="tech-scroller">
                        <img src="https://cdn.simpleicons.org/python/CCCCCC" alt="Python" />
                        <img src="https://cdn.simpleicons.org/n8n/CCCCCC" alt="n8n" />
                        <img src="https://cdn.simpleicons.org/docker/CCCCCC" alt="Docker" />
                        <img src="https://cdn.simpleicons.org/postgresql/CCCCCC" alt="PostgreSQL" />
                        <img src="https://cdn.simpleicons.org/anthropic/CCCCCC" alt="Anthropic" /> <img src="https://cdn.simpleicons.org/terraform/CCCCCC" alt="Terraform" />
                        <img src="https://cdn.simpleicons.org/kubernetes/CCCCCC" alt="Kubernetes" />
                        <img src="https://cdn.simpleicons.org/rust/CCCCCC" alt="Rust" />
                        <img src="https://cdn.simpleicons.org/typescript/CCCCCC" alt="TypeScript" />
                        <img src="https://cdn.simpleicons.org/googlecloud/CCCCCC" alt="Google Cloud" />
                        <img src="https://cdn.simpleicons.org/linux/CCCCCC" alt="Linux" />
                        <img src="https://cdn.simpleicons.org/redis/CCCCCC" alt="Redis" />
                        <img src="https://cdn.simpleicons.org/fastapi/CCCCCC" alt="FastAPI" />
                        <img src="https://cdn.simpleicons.org/astro/CCCCCC" alt="Astro" />
                        
                        <img src="https://cdn.simpleicons.org/python/CCCCCC" alt="Python" />
                        <img src="https://cdn.simpleicons.org/n8n/CCCCCC" alt="n8n" />
                        <img src="https://cdn.simpleicons.org/docker/CCCCCC" alt="Docker" />
                        <img src="https://cdn.simpleicons.org/postgresql/CCCCCC" alt="PostgreSQL" />
                        <img src="https://cdn.simpleicons.org/anthropic/CCCCCC" alt="Anthropic" />
                        <img src="https://cdn.simpleicons.org/terraform/CCCCCC" alt="Terraform" />
                        <img src="https://cdn.simpleicons.org/kubernetes/CCCCCC" alt="Kubernetes" />
                        <img src="https://cdn.simpleicons.org/rust/CCCCCC" alt="Rust" />
                        <img src="https://cdn.simpleicons.org/typescript/CCCCCC" alt="TypeScript" />
                        <img src="https://cdn.simpleicons.org/googlecloud/CCCCCC" alt="Google Cloud" />
                        <img src="https://cdn.simpleicons.org/linux/CCCCCC" alt="Linux" />
                        <img src="https://cdn.simpleicons.org/redis/CCCCCC" alt="Redis" />
                        <img src="https://cdn.simpleicons.org/fastapi/CCCCCC" alt="FastAPI" />
                        <img src="https://cdn.simpleicons.org/astro/CCCCCC" alt="Astro" />
                </div>
            </div>
            
        </section>
        <section id="services" class="services-section">
            <div class="section-header">
                <span class="badge">CAPABILITIES</span>
                <h2>What We <span class="text-gradient">Engineer</span></h2>
                <p class="section-subtitle">Specialized solutions for complex operational challenges</p>
            </div>

            <div class="services-track">
                <div class="card">
                    <div class="card-content">
                        <div class="card-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                            </svg>
                        </div>
                        <div class="card-header">01 // AUTOMATION</div>
                        <h3>Workflow Orchestration</h3>
                        <p>N8n-powered automation pipelines that eliminate repetitive tasks. From data scraping to CRM integration, we build workflows that run 24/7.</p>
                        <ul class="feature-list">
                            <li>Lead generation automation</li>
                            <li>Data processing pipelines</li>
                            <li>Multi-system integration</li>
                        </ul>
                    </div>
                </div>

                <div class="card">
                    <div class="card-content">
                        <div class="card-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <rect x="2" y="3" width="20" height="14" rx="2"/>
                                <path d="M8 21h8M12 17v4"/>
                            </svg>
                        </div>
                        <div class="card-header">02 // AI ENGINEERING</div>
                        <h3>Custom ML Models</h3>
                        <p>Computer vision, NLP, and predictive analytics tailored to your domain. We train models on your data and deploy them on sovereign infrastructure.</p>
                        <ul class="feature-list">
                            <li>Computer vision systems</li>
                            <li>Classification models</li>
                            <li>Anomaly detection</li>
                        </ul>
                    </div>
                </div>

                <div class="card">
                    <div class="card-content">
                        <div class="card-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                                <line x1="12" y1="22.08" x2="12" y2="12"/>
                            </svg>
                        </div>
                        <div class="card-header">03 // DATA ENGINEERING</div>
                        <h3>Pipeline Architecture</h3>
                        <p>ETL pipelines, data warehousing, and real-time processing systems. We turn scattered data into actionable intelligence.</p>
                        <ul class="feature-list">
                            <li>ETL pipeline development</li>
                            <li>Database optimization</li>
                            <li>Real-time streaming</li>
                        </ul>
                    </div>
                </div>

                <div class="card">
                    <div class="card-content">
                        <div class="card-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="M12 6v6l4 2"/>
                            </svg>
                        </div>
                        <div class="card-header">04 // OPTIMIZATION</div>
                        <h3>Process Efficiency</h3>
                        <p>Audit existing workflows, identify bottlenecks, and implement solutions that compress weeks of work into hours.</p>
                        <ul class="feature-list">
                            <li>Workflow audits</li>
                            <li>Bottleneck analysis</li>
                            <li>Performance optimization</li>
                        </ul>
                    </div>
                </div>

                <div class="card">
                    <div class="card-content">
                        <div class="card-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                <circle cx="9" cy="7" r="4"/>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                        <div class="card-header">05 // SCALABILITY</div>
                        <h3>Phantom Workforce</h3>
                        <p>Grow output without growing payroll. Our systems act as silent, tireless employees that scale instantly with demand.</p>
                        <ul class="feature-list">
                            <li>Horizontal scaling</li>
                            <li>Load balancing</li>
                            <li>Containerization</li>
                        </ul>
                    </div>
                </div>

                <div class="card">
                    <div class="card-content">
                        <div class="card-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                                <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
                            </svg>
                        </div>
                        <div class="card-header">06 // INTEGRATION</div>
                        <h3>Stack Agnostic</h3>
                        <p>We don't force you into a box. Legacy servers or cutting-edge cloud—we build adapters to integrate your entire ecosystem.</p>
                        <ul class="feature-list">
                            <li>API development</li>
                            <li>Legacy system integration</li>
                            <li>Microservices architecture</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <section id="work" class="case-study-section">
            <div class="section-header">
                <span class="badge">DEPLOYED INTELLIGENCE</span>
                <h2>Case <span class="text-gradient">Studies</span></h2>
                <p class="section-subtitle">Real systems solving real problems</p>
            </div>

            <div class="case-card">
                <div class="case-visual">
                    <div class="app-frame">
                        <div class="app-header">
                            <span class="dot red"></span>
                            <span class="dot yellow"></span>
                            <span class="dot green"></span>
                            <span class="address-bar">https://vault-1.aurascalelabs.internal/geo-ai</span>
                        </div>
                        <img src="/forams-ui.png" alt="Forams Classifier Interface" class="project-screenshot" />
                    </div>
                </div>

                <div class="case-info">
                    <div class="case-meta">
                        <span class="meta-tag">COMPUTER VISION</span>
                        <span class="meta-tag">PYTORCH</span>
                        <span class="meta-tag">GEOLOGY</span>
                    </div>
                    
                    <h3>Automated Foram Classification</h3>
                    
                    <p class="description">
                        Manual microfossil identification is slow, expensive, and error-prone. We engineered a 
                        <strong>Computer Vision Pipeline</strong> capable of classifying geological samples in milliseconds 
                        with near-perfect accuracy—eliminating weeks of manual lab work.
                    </p>
                    
                    <div class="challenge-solution">
                        <div class="cs-block">
                            <h4>Challenge</h4>
                            <p>Geologists spent 15-20 hours per sample manually identifying microfossils under microscopes. 
                            High variance in human classification led to inconsistent results across teams.</p>
                        </div>
                        <div class="cs-block">
                            <h4>Solution</h4>
                            <p>Custom PyTorch model trained on 10,000+ labeled images. Deployed via Streamlit for 
                            real-time inference. Integrated with existing lab workflows via API.</p>
                        </div>
                    </div>

                    <div class="stats-grid">
                        <div class="stat">
                            <span class="value">99.8%</span>
                            <span class="label">Classification Accuracy</span>
                        </div>
                        <div class="stat">
                            <span class="value">5ms</span>
                            <span class="label">Inference Time</span>
                        </div>
                        <div class="stat">
                            <span class="value">18hrs</span>
                            <span class="label">Saved per Sample</span>
                        </div>
                    </div>

                    <div class="tech-stack-mini">
                        <strong>Stack:</strong>
                        <span>PyTorch</span>
                        <span>Streamlit</span>
                        <span>Python</span>
                        <span>Computer Vision</span>
                    </div>

                    <a href="https://forams-classifier-4g.streamlit.app/" target="_blank" class="live-link">
                        VIEW LIVE SYSTEM <span class="arrow">→</span>
                    </a>
                </div>
            </div>
        </section>

        <section id="process" class="process-section">
            <div class="section-header">
                <span class="badge">METHODOLOGY</span>
                <h2>How We <span class="text-gradient">Work</span></h2>
                <p class="section-subtitle">Transparent, iterative, results-driven</p>
            </div>

            <div class="process-timeline">
                <div class="process-step">
                    <div class="step-number">01</div>
                    <div class="step-content">
                        <h3>Discovery & Audit</h3>
                        <p>We analyze your current workflows, identify bottlenecks, and quantify potential gains. 
                        You get a detailed report with ROI projections before committing to anything.</p>
                        <div class="step-duration">1-2 weeks</div>
                    </div>
                </div>

                <div class="process-step">
                    <div class="step-number">02</div>
                    <div class="step-content">
                        <h3>Architecture & Design</h3>
                        <p>We design the system architecture, select optimal tech stack, and create a detailed 
                        implementation roadmap. You approve every technical decision before we write code.</p>
                        <div class="step-duration">1 week</div>
                    </div>
                </div>

                <div class="process-step">
                    <div class="step-number">03</div>
                    <div class="step-content">
                        <h3>Development & Testing</h3>
                        <p>Rapid prototyping with weekly demos. We build in sprints, testing continuously against 
                        real data. You see progress every week, not after months of black-box development.</p>
                        <div class="step-duration">2-6 weeks</div>
                    </div>
                </div>

                <div class="process-step">
                    <div class="step-number">04</div>
                    <div class="step-content">
                        <h3>Deployment & Training</h3>
                        <p>We deploy to your infrastructure (or ours), train your team, and provide comprehensive 
                        documentation. The system runs autonomously, but you understand every component.</p>
                        <div class="step-duration">1 week</div>
                    </div>
                </div>

                <div class="process-step">
                    <div class="step-number">05</div>
                    <div class="step-content">
                        <h3>Monitoring & Optimization</h3>
                        <p>30-60 days of active monitoring, performance tuning, and adjustment. We ensure the 
                        system delivers promised ROI and optimize based on real-world usage patterns.</p>
                        <div class="step-duration">Ongoing</div>
                    </div>
                </div>
            </div>
        </section>

        <section id="tech" class="tech-section">
            <div class="section-header">
                <span class="badge">INFRASTRUCTURE</span>
                <h2>Tech <span class="text-gradient">Stack</span></h2>
                <p class="section-subtitle">Enterprise-grade tools, sovereign infrastructure</p>
            </div>

            <div class="tech-categories">
                <div class="tech-category">
                    <h3>Automation & Orchestration</h3>
                    <div class="tech-items">
                        <div class="tech-item">
                            <strong>N8n</strong>
                            <span>Workflow automation & integration</span>
                        </div>
                        <div class="tech-item">
                            <strong>Apache Airflow</strong>
                            <span>Complex pipeline orchestration</span>
                        </div>
                        <div class="tech-item">
                            <strong>Kubernetes</strong>
                            <span>Container orchestration & scaling</span>
                        </div>
                    </div>
                </div>

                <div class="tech-category">
                    <h3>AI & Machine Learning</h3>
                    <div class="tech-items">
                        <div class="tech-item">
                            <strong>PyTorch</strong>
                            <span>Deep learning & computer vision</span>
                        </div>
                        <div class="tech-item">
                            <strong>OpenAI API</strong>
                            <span>LLM integration & RAG systems</span>
                        </div>
                        <div class="tech-item">
                            <strong>TensorFlow</strong>
                            <span>Production ML models</span>
                        </div>
                    </div>
                </div>

                <div class="tech-category">
                    <h3>Data Engineering</h3>
                    <div class="tech-items">
                        <div class="tech-item">
                            <strong>PostgreSQL</strong>
                            <span>Relational data storage</span>
                        </div>
                        <div class="tech-item">
                            <strong>Redis</strong>
                            <span>Caching & real-time data</span>
                        </div>
                        <div class="tech-item">
                            <strong>Apache Kafka</strong>
                            <span>Event streaming</span>
                        </div>
                    </div>
                </div>

                <div class="tech-category">
                    <h3>Development & Deployment</h3>
                    <div class="tech-items">
                        <div class="tech-item">
                            <strong>Docker</strong>
                            <span>Containerization</span>
                        </div>
                        <div class="tech-item">
                            <strong>Terraform</strong>
                            <span>Infrastructure as code</span>
                        </div>
                        <div class="tech-item">
                            <strong>GitHub Actions</strong>
                            <span>CI/CD pipelines</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="vault-callout">
                <div class="vault-icon">
                    <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                </div>
                <div class="vault-content">
                    <h3>Powered by <span class="highlight">The Vault</span></h3>
                    <p>Our sovereign infrastructure ensures your data never touches third-party servers. 
                    Self-hosted n8n, private Docker registry, dedicated GPU compute—everything runs on hardware we control.</p>
                    <ul class="vault-benefits">
                        <li><strong>100% Data Privacy</strong> – Your data stays yours</li>
                        <li><strong>Zero Vendor Lock-in</strong> – Open-source foundation</li>
                        <li><strong>Maximum Performance</strong> – Dedicated resources</li>
                        <li><strong>Cost Efficiency</strong> – No per-seat or API usage fees</li>
                    </ul>
                </div>
            </div>
        </section>

        <section id="pricing" class="pricing-section">
            <div class="section-header">
                <span class="badge">ENGAGEMENT MODELS</span>
                <h2>How We <span class="text-gradient">Engage</span></h2>
                <p class="section-subtitle">Flexible models for different project scales</p>
            </div>

            <div class="pricing-grid">
                <div class="pricing-card">
                    <div class="pricing-header">
                        <h3>Audit</h3>
                        <div class="price">$1,500</div>
                        <div class="price-subtitle">One-time</div>
                    </div>
                    <p class="pricing-description">Comprehensive workflow analysis and ROI projection</p>
                    <ul class="pricing-features">
                        <li>Process mapping</li>
                        <li>Bottleneck identification</li>
                        <li>Tech stack recommendations</li>
                        <li>Detailed ROI report</li>
                        <li>Implementation roadmap</li>
                    </ul>
                    <a href="#contact" class="pricing-cta">Request Audit</a>
                </div>

                <div class="pricing-card featured">
                    <div class="featured-badge">MOST POPULAR</div>
                    <div class="pricing-header">
                        <h3>Fixed Project</h3>
                        <div class="price">$5k - $25k</div>
                        <div class="price-subtitle">Project-based</div>
                    </div>
                    <p class="pricing-description">End-to-end system development with defined scope</p>
                    <ul class="pricing-features">
                        <li>Custom automation workflows</li>
                        <li>ML model development</li>
                        <li>Data pipeline architecture</li>
                        <li>Deployment & training</li>
                        <li>60-day support included</li>
                    </ul>
                    <a href="#contact" class="pricing-cta">Start Project</a>
                </div>

                <div class="pricing-card">
                    <div class="pricing-header">
                        <h3>Retainer</h3>
                        <div class="price">$8k - $15k</div>
                        <div class="price-subtitle">Per month</div>
                    </div>
                    <p class="pricing-description">Ongoing development, optimization, and support</p>
                    <ul class="pricing-features">
                        <li>Dedicated engineering hours</li>
                        <li>Priority support</li>
                        <li>Continuous optimization</li>
                        <li>New feature development</li>
                        <li>Monthly strategy calls</li>
                    </ul>
                    <a href="#contact" class="pricing-cta">Discuss Retainer</a>
                </div>
            </div>

            <div class="pricing-note">
                <p><strong>Note:</strong> All pricing is project-dependent. Book a discovery call for accurate scoping.</p>
            </div>
        </section>

        <section id="contact" class="contact-section">
            <div class="section-header">
                <span class="badge">GET STARTED</span>
                <h2>Let's Build <span class="text-gradient">Something</span></h2>
                <p class="section-subtitle">Book a free 30-minute discovery call</p>
            </div>

            <div class="contact-container">
                <div class="contact-info">
                    <h3>What to Expect</h3>
                    <ul class="contact-checklist">
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 6L9 17l-5-5"/>
                            </svg>
                            <span>30-minute technical discussion</span>
                        </li>
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 6L9 17l-5-5"/>
                            </svg>
                            <span>Workflow bottleneck identification</span>
                        </li>
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 6L9 17l-5-5"/>
                            </svg>
                            <span>Preliminary ROI estimation</span>
                        </li>
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 6L9 17l-5-5"/>
                            </svg>
                            <span>Technical approach overview</span>
                        </li>
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 6L9 17l-5-5"/>
                            </svg>
                            <span>Next steps & timeline</span>
                        </li>
                    </ul>

                    <div class="contact-methods">
                        <a href="mailto:contact@aurascalelabs.com" class="contact-method">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                            <div>
                                <strong>Email</strong>
                                <span>contact@aurascalelabs.com</span>
                            </div>
                        </a>

                        <a href="https://cal.com/aurascalelabs" target="_blank" class="contact-method">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                <line x1="16" y1="2" x2="16" y2="6"/>
                                <line x1="8" y1="2" x2="8" y2="6"/>
                                <line x1="3" y1="10" x2="21" y2="10"/>
                            </svg>
                            <div>
                                <strong>Schedule Call</strong>
                                <span>cal.com/aurascalelabs</span>
                            </div>
                        </a>
                    </div>
                </div>

                <form class="contact-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
                    <div class="form-group">
                        <label>Name</label>
                        <input type="text" name="name" required placeholder="John Doe">
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" name="email" required placeholder="john@company.com">
                    </div>

                    <div class="form-group">
                        <label>Company</label>
                        <input type="text" name="company" placeholder="Acme Inc.">
                    </div>

                    <div class="form-group">
                        <label>Project Type</label>
                        <select name="project_type">
                            <option value="">Select...</option>
                            <option value="automation">Workflow Automation</option>
