---
import Layout from '../layouts/Layout.astro';
---

<Layout
    title="AuraScaleLabs | Data Analytics & Process Automation for Produce"
    description="We help produce distributors in Nogales and McAllen automate invoice reconciliation, gain real-time pricing visibility, and optimize cross-border operations."
>

    <div class="background-grid"></div>
    <canvas id="connections-canvas"></canvas>

    <nav id="navbar">
        <div class="nav-container">
            <div class="logo">AuraScale<span class="highlight">Labs</span></div>
            <div class="nav-links">
                <a href="#services">Solutions</a>
                <a href="#work">Results</a>
                <a href="#process">Process</a>
                <a href="#pricing">Pricing</a>
                <a href="#contact" class="cta-button">Book a Call</a>
            </div>
            <button class="mobile-menu-btn" id="mobile-menu-btn">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </nav>

    <main>
        <section class="hero" id="hero-section">


            <div class="hero-content">
                <div class="badge">THE ANALYTICS PARTNER FOR PRODUCE</div>
                <h1>Running a produce business is complex. <br/><span class="text-gradient-animated">Data shouldn't make it harder.</span></h1>
                <p class="subtitle">
                    AuraScaleLabs helps produce distributors and importers in the US-Mexico border
                    automate invoice reconciliation, gain real-time visibility into inventory and pricing,
                    and eliminate manual data work — so you can focus on moving product.
                </p>

                <div class="hero-cta">
                    <a href="#contact" class="primary-btn">Book a Discovery Call</a>
                    <a href="#services" class="secondary-btn">See How We Help →</a>
                </div>

                <div class="hero-proof">
                    <div class="proof-point">
                        <span class="proof-icon">→</span>
                        <span>Invoice reconciliation automated in &lt;6 weeks</span>
                    </div>
                    <div class="proof-point">
                        <span class="proof-icon">→</span>
                        <span>You own the pipeline. Zero vendor lock-in.</span>
                    </div>
                    <div class="proof-point">
                        <span class="proof-icon">→</span>
                        <span>Built for US-Mexico produce operations</span>
                    </div>
                </div>

                <div class="tech-scroller">
                    <img src="https://cdn.simpleicons.org/python/CCCCCC" alt="Python" />
                    <img src="https://cdn.simpleicons.org/n8n/CCCCCC" alt="n8n" />
                    <img src="https://cdn.simpleicons.org/docker/CCCCCC" alt="Docker" />
                    <img src="https://cdn.simpleicons.org/postgresql/CCCCCC" alt="PostgreSQL" />
                    <img src="https://cdn.simpleicons.org/googlecloud/CCCCCC" alt="Google Cloud" />
                    <img src="https://cdn.simpleicons.org/metabase/CCCCCC" alt="Metabase" />

                    <img src="https://cdn.simpleicons.org/python/CCCCCC" alt="Python" />
                    <img src="https://cdn.simpleicons.org/n8n/CCCCCC" alt="n8n" />
                    <img src="https://cdn.simpleicons.org/docker/CCCCCC" alt="Docker" />
                    <img src="https://cdn.simpleicons.org/postgresql/CCCCCC" alt="PostgreSQL" />
                    <img src="https://cdn.simpleicons.org/googlecloud/CCCCCC" alt="Google Cloud" />
                    <img src="https://cdn.simpleicons.org/metabase/CCCCCC" alt="Metabase" />
                </div>
            </div>

        </section>
        <section id="services" class="services-section">
            <div class="section-header reveal">
                <span class="badge">WHAT WE SOLVE</span>
                <h2>Solutions built for <span class="text-gradient">produce operations</span></h2>
                <p class="section-subtitle">Purpose-built analytics and automation for the produce supply chain</p>
            </div>

            <div class="services-track reveal">
                <div class="card">
                    <div class="card-content">
                        <div class="card-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                                <line x1="16" y1="13" x2="8" y2="13"/>
                                <line x1="16" y1="17" x2="8" y2="17"/>
                            </svg>
                        </div>
                        <div class="card-header">01 // INVOICES</div>
                        <h3>Automated Invoice Reconciliation</h3>
                        <p>Stop matching invoices by hand. We connect your systems to automatically match purchases, sales, and payments — flagging discrepancies before they cost you.</p>
                        <ul class="feature-list">
                            <li>Cross-system invoice matching</li>
                            <li>Discrepancy alerts</li>
                            <li>Automated reporting</li>
                        </ul>
                    </div>
                </div>

                <div class="card">
                    <div class="card-content">
                        <div class="card-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <rect x="2" y="3" width="20" height="14" rx="2"/>
                                <path d="M8 21h8M12 17v4"/>
                            </svg>
                        </div>
                        <div class="card-header">02 // VISIBILITY</div>
                        <h3>Real-Time Pricing & Inventory</h3>
                        <p>Know exactly what you have, where it is, and what it's worth — in real time. No more calling the warehouse or digging through spreadsheets.</p>
                        <ul class="feature-list">
                            <li>Live inventory tracking</li>
                            <li>Market price feeds</li>
                            <li>Margin analysis</li>
                        </ul>
                    </div>
                </div>

                <div class="card">
                    <div class="card-content">
                        <div class="card-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                                <line x1="12" y1="22.08" x2="12" y2="12"/>
                            </svg>
                        </div>
                        <div class="card-header">03 // COMPLIANCE</div>
                        <h3>Cross-Border Document Automation</h3>
                        <p>Phytosanitary certificates, customs forms, USDA inspections — we digitize and automate the paperwork that slows down your cross-border flow.</p>
                        <ul class="feature-list">
                            <li>OCR document extraction</li>
                            <li>Compliance tracking</li>
                            <li>Digital audit trails</li>
                        </ul>
                    </div>
                </div>

                <div class="card">
                    <div class="card-content">
                        <div class="card-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/>
                            </svg>
                        </div>
                        <div class="card-header">04 // COLD CHAIN</div>
                        <h3>Cold Chain & Shelf-Life Intelligence</h3>
                        <p>Temperature excursions destroy margins. We build monitoring systems that predict shelf life and alert you before product is compromised.</p>
                        <ul class="feature-list">
                            <li>Temperature monitoring</li>
                            <li>Shelf-life prediction</li>
                            <li>Alert automation</li>
                        </ul>
                    </div>
                </div>

                <div class="card">
                    <div class="card-content">
                        <div class="card-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <line x1="18" y1="20" x2="18" y2="10"/>
                                <line x1="12" y1="20" x2="12" y2="4"/>
                                <line x1="6" y1="20" x2="6" y2="14"/>
                            </svg>
                        </div>
                        <div class="card-header">05 // INTELLIGENCE</div>
                        <h3>Sales & Market Analytics</h3>
                        <p>Understand your buyers, predict demand, and spot pricing trends before your competition. Turn your transaction history into a strategic advantage.</p>
                        <ul class="feature-list">
                            <li>Buyer pattern analysis</li>
                            <li>Demand forecasting</li>
                            <li>Price trend dashboards</li>
                        </ul>
                    </div>
                </div>

                <div class="card">
                    <div class="card-content">
                        <div class="card-icon">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                                <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
                            </svg>
                        </div>
                        <div class="card-header">06 // INTEGRATION</div>
                        <h3>ERP & Legacy System Integration</h3>
                        <p>Your data lives in QuickBooks, Excel, email, and maybe an old ERP. We connect everything into one pipeline without forcing you to switch systems.</p>
                        <ul class="feature-list">
                            <li>QuickBooks/ERP connectors</li>
                            <li>Excel automation</li>
                            <li>Email data extraction</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <section id="work" class="case-study-section">
            <div class="section-header reveal">
                <span class="badge">RESULTS</span>
                <h2>Real results for <span class="text-gradient">produce operations</span></h2>
                <p class="section-subtitle">Measurable impact on your bottom line</p>
            </div>

            <div class="case-card reveal-scale">
                <div class="case-visual">
                    <div class="case-dashboard">
                        <div class="dashboard-header">
                            <span class="dashboard-title">Invoice Reconciliation Dashboard</span>
                            <span class="dashboard-status">LIVE</span>
                        </div>
                        <div class="dashboard-content">
                            <div class="dashboard-metric">
                                <span class="metric-value">94%</span>
                                <span class="metric-label">Auto-Match Rate</span>
                            </div>
                            <div class="dashboard-metric">
                                <span class="metric-value">12</span>
                                <span class="metric-label">Hrs/Week Saved</span>
                            </div>
                            <div class="dashboard-metric">
                                <span class="metric-value">$4.2k</span>
                                <span class="metric-label">Monthly Recovery</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="case-info">
                    <div class="case-meta">
                        <span class="meta-tag">WORKFLOW AUTOMATION</span>
                        <span class="meta-tag">DATA ENGINEERING</span>
                        <span class="meta-tag">FINANCE OPS</span>
                    </div>

                    <h3>Automated Invoice Reconciliation</h3>

                    <p class="description">
                        A Nogales-based produce distributor was losing 15+ hours per week manually matching invoices
                        across three systems. Price discrepancies went unnoticed until month-end, costing thousands
                        in unrecovered revenue.
                    </p>

                    <div class="challenge-solution">
                        <div class="cs-block">
                            <h4>Challenge</h4>
                            <p>The operations team manually reconciled 200+ invoices weekly across QuickBooks, email,
                            and their legacy ERP. Mismatched prices and missing credits were discovered weeks late.</p>
                        </div>
                        <div class="cs-block">
                            <h4>Solution</h4>
                            <p>We built an automated pipeline using n8n and Python OCR that extracts invoice data,
                            matches transactions across systems, and flags discrepancies in real time — before payments go out.</p>
                        </div>
                    </div>

                    <div class="stats-grid">
                        <div class="stat">
                            <span class="value">94%</span>
                            <span class="label">Auto-Match Rate</span>
                        </div>
                        <div class="stat">
                            <span class="value">12hrs</span>
                            <span class="label">Saved per Week</span>
                        </div>
                        <div class="stat">
                            <span class="value">$4,200</span>
                            <span class="label">Monthly Recovery</span>
                        </div>
                    </div>

                    <div class="tech-stack-mini">
                        <strong>Stack:</strong>
                        <span>n8n</span>
                        <span>Python OCR</span>
                        <span>PostgreSQL</span>
                        <span>API Integration</span>
                    </div>
                </div>
            </div>
        </section>

        <section id="process" class="process-section">
            <div class="section-header reveal">
                <span class="badge">OUR METHODOLOGY</span>
                <h2>How we <span class="text-gradient">work</span></h2>
                <p class="section-subtitle">From audit to deployment in 6 weeks</p>
            </div>

            <div class="process-timeline reveal-stagger">
                <div class="process-step reveal">
                    <div class="step-number">01</div>
                    <div class="step-content">
                        <h3>Operational Audit</h3>
                        <p>We map your current data flow, interview your team, and identify where time and money are being lost.</p>
                        <div class="step-duration">Week 1</div>
                    </div>
                </div>

                <div class="process-step reveal">
                    <div class="step-number">02</div>
                    <div class="step-content">
                        <h3>Pipeline Architecture</h3>
                        <p>We design a custom data pipeline tailored to your operation — not a generic template.</p>
                        <div class="step-duration">Week 2</div>
                    </div>
                </div>

                <div class="process-step reveal">
                    <div class="step-number">03</div>
                    <div class="step-content">
                        <h3>Build & Automate</h3>
                        <p>We build in weekly sprints with demos using YOUR real data. You see progress every week.</p>
                        <div class="step-duration">Weeks 3-5</div>
                    </div>
                </div>

                <div class="process-step reveal">
                    <div class="step-number">04</div>
                    <div class="step-content">
                        <h3>Deployment & Handoff</h3>
                        <p>We deploy, train your team, and hand over full documentation. The system is yours.</p>
                        <div class="step-duration">Week 6</div>
                    </div>
                </div>
            </div>
        </section>

        <section id="tech" class="tech-section">
            <div class="section-header reveal">
                <span class="badge">INFRASTRUCTURE</span>
                <h2>Enterprise-grade <span class="text-gradient">reliability</span></h2>
                <p class="section-subtitle">Production-ready tools you can trust</p>
            </div>

            <div class="tech-categories reveal-stagger">
                <div class="tech-category reveal">
                    <h3>Data Orchestration</h3>
                    <div class="tech-items">
                        <div class="tech-item">
                            <strong>n8n</strong>
                            <span>Workflow automation & integration</span>
                        </div>
                        <div class="tech-item">
                            <strong>Python</strong>
                            <span>OCR & data processing</span>
                        </div>
                        <div class="tech-item">
                            <strong>REST/SOAP APIs</strong>
                            <span>ERP integration</span>
                        </div>
                    </div>
                </div>

                <div class="tech-category reveal">
                    <h3>Storage & Analytics</h3>
                    <div class="tech-items">
                        <div class="tech-item">
                            <strong>PostgreSQL</strong>
                            <span>Relational data storage</span>
                        </div>
                        <div class="tech-item">
                            <strong>Metabase / Supabase</strong>
                            <span>Dashboards & real-time views</span>
                        </div>
                        <div class="tech-item">
                            <strong>AWS / Google Cloud</strong>
                            <span>Scalable infrastructure</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="vault-callout reveal">
                <div class="vault-icon">
                    <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                </div>
                <div class="vault-content">
                    <h3>Your margins <span class="highlight">stay yours.</span></h3>
                    <p>Your data never leaves systems we control. No per-seat fees, no vendor lock-in,
                    no third-party access to your pricing data.</p>
                    <ul class="vault-benefits">
                        <li><strong>100% Data Privacy</strong> – Your data stays yours</li>
                        <li><strong>Zero Vendor Lock-in</strong> – Open-source foundation</li>
                        <li><strong>Read-Only ERP Adapters</strong> – Safe system access</li>
                        <li><strong>Full Audit Trails</strong> – Complete transparency</li>
                    </ul>
                </div>
            </div>
        </section>

        <section id="pricing" class="pricing-section">
            <div class="section-header reveal">
                <span class="badge">ENGAGEMENT MODELS</span>
                <h2>Partnership <span class="text-gradient">structures</span></h2>
                <p class="section-subtitle">Flexible models for different operational needs</p>
            </div>

            <div class="pricing-grid reveal-stagger">
                <div class="pricing-card reveal">
                    <div class="pricing-header">
                        <h3>Discovery</h3>
                        <div class="price">$1,500</div>
                        <div class="price-subtitle">One-time</div>
                    </div>
                    <p class="pricing-description">Full operational diagnostic</p>
                    <ul class="pricing-features">
                        <li>Data flow mapping</li>
                        <li>Bottleneck identification</li>
                        <li>ROI projection</li>
                        <li>Implementation roadmap</li>
                        <li>Written report</li>
                    </ul>
                    <a href="#contact" class="pricing-cta">Request Discovery</a>
                </div>

                <div class="pricing-card featured reveal">
                    <div class="featured-badge">MOST POPULAR</div>
                    <div class="pricing-header">
                        <h3>Build</h3>
                        <div class="price">$5k - $25k</div>
                        <div class="price-subtitle">Project-based</div>
                    </div>
                    <p class="pricing-description">End-to-end custom pipeline</p>
                    <ul class="pricing-features">
                        <li>Custom automation workflows</li>
                        <li>Dashboard development</li>
                        <li>System integration</li>
                        <li>Team training</li>
                        <li>60-day support</li>
                    </ul>
                    <a href="#contact" class="pricing-cta">Start Build</a>
                </div>

                <div class="pricing-card reveal">
                    <div class="pricing-header">
                        <h3>Ongoing</h3>
                        <div class="price">$8k - $15k</div>
                        <div class="price-subtitle">Per month</div>
                    </div>
                    <p class="pricing-description">Continuous optimization</p>
                    <ul class="pricing-features">
                        <li>Dedicated engineering hours</li>
                        <li>Priority support</li>
                        <li>Performance monitoring</li>
                        <li>New feature development</li>
                        <li>Monthly strategy calls</li>
                    </ul>
                    <a href="#contact" class="pricing-cta">Discuss Ongoing</a>
                </div>
            </div>

            <div class="pricing-note">
                <p><strong>Note:</strong> All pricing is project-dependent. Book a discovery call for accurate scoping.</p>
            </div>
        </section>

        <section id="contact" class="contact-section">
            <div class="section-header reveal">
                <span class="badge">GET STARTED</span>
                <h2>Let's talk <span class="text-gradient">operations</span></h2>
                <p class="section-subtitle">Book a free 30-minute discovery call</p>
            </div>

            <div class="contact-container">
                <div class="contact-info reveal-left">
                    <h3>What to Expect</h3>
                    <ul class="contact-checklist">
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 6L9 17l-5-5"/>
                            </svg>
                            <span>30-minute operational review</span>
                        </li>
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 6L9 17l-5-5"/>
                            </svg>
                            <span>Identify your biggest data bottleneck</span>
                        </li>
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 6L9 17l-5-5"/>
                            </svg>
                            <span>Preliminary ROI estimate</span>
                        </li>
                        <li>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 6L9 17l-5-5"/>
                            </svg>
                            <span>Clear next steps — no pressure</span>
                        </li>
                    </ul>

                    <div class="contact-methods">
                        <a href="mailto:support@aurascalelabs.com" class="contact-method">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                            <div>
                                <strong>Email</strong>
                                <span>support@aurascalelabs.com</span>
                            </div>
                        </a>

                        <a href="https://cal.com/aurascalelabs" target="_blank" class="contact-method">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                <line x1="16" y1="2" x2="16" y2="6"/>
                                <line x1="8" y1="2" x2="8" y2="6"/>
                                <line x1="3" y1="10" x2="21" y2="10"/>
                            </svg>
                            <div>
                                <strong>Schedule Call</strong>
                                <span>cal.com/aurascalelabs</span>
                            </div>
                        </a>
                    </div>
                </div>

                <form class="contact-form reveal" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
                    <div class="form-group">
                        <label>Name</label>
                        <input type="text" name="name" required placeholder="John Doe">
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" name="email" required placeholder="john@company.com">
                    </div>

                    <div class="form-group">
                        <label>Company</label>
                        <input type="text" name="company" placeholder="Your produce company">
                    </div>

                    <div class="form-group">
                        <label>Project Type</label>
                        <select name="project_type">
                            <option value="">Select...</option>
                            <option value="invoices">Invoice Reconciliation</option>
                            <option value="visibility">Inventory & Pricing Visibility</option>
                            <option value="documents">Cross-Border Document Processing</option>
                            <option value="coldchain">Cold Chain Analytics</option>
                            <option value="other">Other / Not Sure</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Tell us about your operation</label>
                        <textarea name="message" rows="4" placeholder="What operational challenge is costing you the most time or money right now?"></textarea>
                    </div>

                    <button type="submit" class="form-submit">Send Message</button>

                    <p class="form-note">We respond within 24 hours</p>
                </form>
            </div>
        </section>
    </main>

    <footer>
        <div class="footer-content reveal">
            <div class="footer-brand">
                <div class="logo">AuraScale<span class="highlight">Labs</span></div>
                <p>Data analytics and process automation for produce operations.</p>
            </div>

            <div class="footer-links">
                <div class="footer-column">
                    <h4>Solutions</h4>
                    <a href="#services">Invoice Automation</a>
                    <a href="#services">Pricing Dashboards</a>
                    <a href="#services">Document Processing</a>
                    <a href="#services">System Integration</a>
                </div>

                <div class="footer-column">
                    <h4>Company</h4>
                    <a href="#process">Our Process</a>
                    <a href="#pricing">Engagement Models</a>
                    <a href="#contact">Book a Call</a>
                </div>

                <div class="footer-column">
                    <h4>Connect</h4>
                    <a href="mailto:support@aurascalelabs.com">Email</a>
                    <a href="https://linkedin.com/company/aurascalelabs" target="_blank">LinkedIn</a>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <p>&copy; 2026 AuraScaleLabs. All Systems Operational.</p>
            <div class="footer-legal">
                <a href="/privacy">Privacy Policy</a>
                <a href="/terms">Terms of Service</a>
            </div>
        </div>
    </footer>
</Layout>

<script is:inline>
    // Mobile menu toggle
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const navLinks = document.querySelector('.nav-links');

    if (mobileMenuBtn && navLinks) {
        mobileMenuBtn.addEventListener('click', () => {
            navLinks.classList.toggle('active');
            mobileMenuBtn.classList.toggle('active');
        });
    }

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                if (navLinks) navLinks.classList.remove('active');
                if (mobileMenuBtn) mobileMenuBtn.classList.remove('active');
            }
        });
    });

    // Navbar scroll effect
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
        if (window.pageYOffset > 100) {
            if (navbar) navbar.classList.add('scrolled');
        } else {
            if (navbar) navbar.classList.remove('scrolled');
        }
    });

    // --- CANVAS GLOBAL ---
    const canvas = document.getElementById('connections-canvas');

    if (canvas) {
        const ctx = canvas.getContext('2d');
        let width, height;
        let particles = [];

        // AJUSTES DE DENSIDAD Y OPACIDAD
        const particleCount = 800;
        const connectionDistance = 140;

        const palette = [
            '34, 197, 94',   // Verde
            '16, 185, 129',  // Esmeralda
            '217, 119, 6',   // Ámbar
            '74, 222, 128'   // Verde claro
        ];

        function resize() {
            width = canvas.width = window.innerWidth;
            height = canvas.height = window.innerHeight;
        }

        class Particle {
            constructor() {
                this.x = Math.random() * width;
                this.y = Math.random() * height;
                this.vx = (Math.random() - 0.5) * 0.5;
                this.vy = (Math.random() - 0.5) * 0.5;
                this.size = Math.random() * 1.5 + 0.5;
                this.color = palette[Math.floor(Math.random() * palette.length)];
            }

            update() {
                this.x += this.vx;
                this.y += this.vy;

                if (this.x < 0 || this.x > width) this.vx *= -1;
                if (this.y < 0 || this.y > height) this.vy *= -1;
            }

            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(${this.color}, 0.25)`;
                ctx.fill();
            }
        }

        function init() {
            resize();
            particles = [];
            for (let i = 0; i < particleCount; i++) {
                particles.push(new Particle());
            }
        }

        function animate() {
            ctx.clearRect(0, 0, width, height);

            particles.forEach(p => {
                p.update();
                p.draw();
            });

            for (let i = 0; i < particles.length; i++) {
                for (let j = i + 1; j < particles.length; j++) {
                    const dx = particles[i].x - particles[j].x;
                    const dy = particles[i].y - particles[j].y;
                    const distance = Math.sqrt(dx * dx + dy * dy);

                    if (distance < connectionDistance) {
                        const opacity = (1 - (distance / connectionDistance)) * 0.12;

                        ctx.beginPath();
                        ctx.strokeStyle = `rgba(${particles[i].color}, ${opacity})`;
                        ctx.lineWidth = 1;
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        ctx.stroke();
                    }
                }
            }
            requestAnimationFrame(animate);
        }

        init();
        animate();
        window.addEventListener('resize', resize);
    }

    // --- SCROLL REVEAL ---
    const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                revealObserver.unobserve(entry.target);
            }
        });
    }, {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
    });

    document.querySelectorAll('.reveal, .reveal-left, .reveal-scale').forEach(el => {
        revealObserver.observe(el);
    });
</script>
